local a = game:GetService("Players")
local b = game:GetService("RunService")
local c = a.LocalPlayer

local e, f, g, h = c.Character, nil, nil, Vector3.zero

local function i(j)
	e = j
	f = j:WaitForChild("HumanoidRootPart")
	g = j:WaitForChild("Humanoid")
	h = Vector3.zero
end

if c.Character then
	i(c.Character)
end
c.CharacterAdded:Connect(i)

b.Heartbeat:Connect(function()
	local d = _G.cfg
	if not d or not e or not f or not g then
		return
	end

	local k = c:GetNetworkPing()
	local l = math.clamp(d.Prediction + k * 0.16, 0.09, 0.25)
	local m = math.clamp(d.Smoothness + k * 0.065, 0.09, 0.2)

	local n = f.Velocity
	local o = Vector3.new(n.X, n.Y * 0.35, n.Z) * l
	h = h:Lerp(o, m)

	g.CameraOffset = f.CFrame:VectorToObjectSpace(-h + Vector3.new(0, 0, 0))

	local p = f.CFrame
	f.CFrame = p + h

	b.RenderStepped:Wait()

	if f.Parent then
		f.CFrame = p
	end
end)
